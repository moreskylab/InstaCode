# Copy this file to .env and fill in real values before deploying.
# .env is gitignored and must never be committed.

# Generate a key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-string

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated — add your PythonAnywhere subdomain
# e.g. yourusername.pythonanywhere.com
ALLOWED_HOSTS=moreskylab3.pythonanywhere.com

# Must start with https:// — same value(s) as ALLOWED_HOSTS
CSRF_TRUSTED_ORIGINS=https://moreskylab3.pythonanywhere.com
